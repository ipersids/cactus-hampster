{
  "name": "@party/proto",
  "version": "1.0.0",
  "type": "module",
  "exports": {
		"./controller-types-v1": "./generated/controller-types/controller_types_v1.ts",
		"./host-types-v1": "./generated/host-types/host_types_v1.ts"
	},
  "scripts": {
		"generate": "mkdir -p generated && protoc -I ../../proto --plugin=./node_modules/.bin/protoc-gen-ts_proto --ts_proto_opt=esModuleInterop=true --ts_proto_out=./generated ../../proto/**/*.proto"
  },
  "devDependencies": {
		"ts-proto": "^2.11.5"
	}
}